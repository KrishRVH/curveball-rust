# Generated by Cargo and rustc.
/target/
**/*.rs.bk

# Local game state produced by copied/running binaries outside Cargo's target dir.
highscores.txt

# Local parity/debug captures and profiling output. Store intentional screenshots
# or fixtures under docs/, assets/, tests/, or reference/ with explicit names.
/screenshots/
/captures/
/perf/
*.log
*.profraw
*.profdata
lcov.info
cobertura.xml
tarpaulin-report.html
/coverage/

# Local environment and machine-specific config.
.env
.env.*
!.env.example
!.env.sample
!.env.template
mise.local.toml
mise.*.local.toml
.mise.local.toml
.mise.*.local.toml
mise.local.lock
mise.*.local.lock
.mise.local.lock
.mise.*.local.lock

# OS/editor scratch files. Keep shareable project config trackable by default.
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.#*

# Crash dumps and temporary scratch directories.
core
core.*
/.cache/
/.tmp/
/tmp/
